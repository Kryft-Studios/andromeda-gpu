{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",

    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "useDefineForClassFields": true,

    "skipLibCheck": true,
    "noEmit": false,
    "declaration":true,
    "types": ["@webgpu/types"],
    "lib": ["Decorators","DOM", "DOM.Iterable", "DOM.AsyncIterable","ESNext"],
    "noImplicitAny":true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitThis": true,
  },
  "include": ["src"]
}
