{
	"devDependencies": {
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"dts-minify": "^0.3.3",
		"eslint": "^10.1.0",
		"node": "^25.8.2",
		"terser": "^5.46.1",
		"typescript": "^6.0.2"
	},
	"name": "@agpu/utils",
	"version": "1.0.1",
	"scripts": {
		"minify:js": "node --no-warnings minify-js.js",
		"minify:dts": "node --no-warnings minify-dts.js",
		"minify:end": "node --no-warnings minify-end.js",
		"tsc": "tsc",
		"lint": "eslint",
		"build": "node --no-warnings cmd/build.js",
		"prepublishOnly":"pnpm build"
	},
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"default": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./vertices": {
			"default": "./dist/vertices/index.js",
			"types": "./dist/vertices/index.d.ts"
		},
		"./indices": {
			"default":"./dist/indices/index.js",
			"types":"./dist/indices/index.d.ts"
		},
		"./vec/3": {
			"default":"./dist/maths/vector/vec3/index.js",
			"types":"./dist/maths/vector/vec3/index.d.ts"
		},
		"./vec/2": {
			"default":"./dist/maths/vector/vec2/index.js",
			"types": "./dist/maths/vector/vec2/index.d.ts"
		},
		"./vec/4": {
			"default":"./dist/maths/vector/vec4/index.js",
			"types":"./dist/maths/vector/vec4/index.d.ts"
		},
		"./mat/2":{
			"default":"./dist/maths/matrix/mat2/index.js",
			"types":"./dist/maths/matrix/mat2/index.d.ts"
		},
		"./mat/3": {
			"default":"./dist/maths/matrix/mat3/index.js",
			"types":"./dist/maths/matrix/mat3/index.d.ts"
		},
		"./mat/2d": {
			"default":"./dist/maths/matrix/mat2d/index.js",
			"types":"./dist/maths/matrix/mat2d/index.d.ts"
		},
		"./mat/4":{
			"default":"./dist/maths/matrix/mat4/index.js",
			"types":"./dist/maths/matrix/mat4/index.d.ts"
		},
		"./color": {
			"default":"./dist/maths/color/index.js",
			"types":"./dist/maths/color/index.d.ts"
		}
	},
	"dependencies": {
		"gl-matrix": "^3.4.4"
	}
}
