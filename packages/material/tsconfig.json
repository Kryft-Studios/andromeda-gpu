{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2022", "DOM", "DOM.Iterable", "DOM.AsyncIterable", "Decorators"],
    "types": ["@webgpu/types"],
    
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "stripInternal": true, 
    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["src"]
}