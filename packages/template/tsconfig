{
  "compilerOptions": {
    "target": "es2024",
    "module": "nodenext",
    "moduleResolution": "nodenext",

    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "lib": ["Decorators","DOM", "DOM.Iterable", "DOM.AsyncIterable", "ESNext"]
  },
  "include": ["src"]
}
